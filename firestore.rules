rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User profile validation
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 256)) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 256)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 512)) &&
             (!('mobile' in data) || (data.mobile is string && data.mobile.size() <= 32)) &&
             (!('designation' in data) || (data.designation is string && data.designation.size() <= 128)) &&
             (!('customLogo' in data) || (data.customLogo is string && data.customLogo.size() <= 1048576)) &&
             (!('onboardingCompleted' in data) || (data.onboardingCompleted is bool));
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'lastLogin', 'country', 'displayName', 'name', 'address', 'mobile', 
          'designation', 'onboardingCompleted', 'photoURL', 'email', 'customLogo',
          'maritalStatus', 'notificationLanguage', 'emailNotificationsEnabled', 
          'updatedAt', 'plan'
        ])
      );
      
      // Calculations Subcollection
      match /calculations/{calculationId} {
        function isValidCalculation(data) {
          return data.keys().hasAll(['heirs', 'assets', 'country', 'timestamp']) &&
                 data.heirs is map &&
                 data.assets is map &&
                 data.country is string && data.country.size() <= 10;
        }

        // For list queries, the rule must validate the resource path variables
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCalculation(incoming()) && incoming().timestamp == request.time;
        allow delete: if isOwner(userId);
      }
    }

    // Feedback
    match /feedback/{feedbackId} {
      function isValidFeedback(data) {
        return data.keys().hasAll(['uid', 'type', 'message', 'timestamp']) &&
               data.uid is string &&
               data.type in ['discrepancy', 'suggestion', 'other'] &&
               data.message is string && data.message.size() <= 2000;
      }
      allow create: if isSignedIn() && isValidFeedback(incoming()) && incoming().uid == request.auth.uid;
    }
  }
}
