rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // No public listing of users
      allow create, update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if false;

      // Calculations
      match /calculations/{calculationId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Feedback
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false; 
    }
  }
}
