{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    },
    "Calculation": {
      "title": "Calculation",
      "description": "Saved inheritance calculation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "deceasedName": { "type": "string" },
        "countryCode": { "type": "string" },
        "madhhab": { "type": "string" },
        "assets": {
          "type": "object",
          "properties": {
            "land": { "type": "number" },
            "money": { "type": "number" },
            "gold": { "type": "number" },
            "silver": { "type": "number" }
          }
        },
        "selectedHeirs": {
          "type": "object",
          "description": "Map of heirId to count"
        },
        "result": {
          "type": "object",
          "description": "The computed CalculationResult"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "countryCode", "assets", "selectedHeirs", "result", "createdAt", "updatedAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "type", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/calculations/{calculationId}": {
      "schema": "Calculation",
      "description": "Stored calculations"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback submissions"
    }
  }
}
