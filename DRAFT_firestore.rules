rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 6
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 256))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1024))
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidCalculation(data) {
      return data.keys().hasAll(['userId', 'countryCode', 'assets', 'selectedHeirs', 'result', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.countryCode is string && data.countryCode.size() <= 10
        && (data.deceasedName == null || (data.deceasedName is string && data.deceasedName.size() <= 256))
        && data.assets is map
        && data.selectedHeirs is map
        && data.result is map
        && data.createdAt <= request.time
        && data.updatedAt == request.time;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId)
        && incoming().updatedAt == request.time
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt;
    }

    match /calculations/{calculationId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCalculation(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(existing().userId) 
        && isValidCalculation(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(existing().userId);
    }
  }
}
